{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">        
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-incoming').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-incoming">
          <div class="table-responsive">
            <table class="table table-bordered table-hover">
              <thead>
                <tr>
                  <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                  <td class="text-left">{{ column_name }}</td>
                  <td class="text-right">{{ column_contacts }}</td>
                  <td class="text-left" style="width: 50%;">{{ column_message }}</td>
                  <td class="text-left">{{ column_dates }}</td>
                  <td class="text-left">{{ column_status }}</td>
                  <td class="text-right">{{ column_action }}</td>
                </tr>
              </thead>
              <tbody>
                {% if incomings %}
                {% for incoming in incomings %}
                <tr>
                  <td class="text-center">{% if incoming.incoming_id in selected %}
                    <input type="checkbox" name="selected[]" value="{{ incoming.incoming_id }}" checked="checked" />
                    {% else %}
                    <input type="checkbox" name="selected[]" value="{{ incoming.incoming_id }}" />
                    {% endif %}</td>
                  <td class="text-left">
                    <div>
                      <b>{{ incoming.name }}</b>
                      {% if incoming.customer %}
                      <a href="{{ incoming.customer }}" target="_blank" class="btn btn-xs btn-info" data-toggle="tooltip" title="{{ text_customer }}">
                        <i class="fa fa-user"></i>
                      </a>
                      {% endif %}
                    </div>                    
                    <div><span class="label label-success">{{ incoming.type }}</span></div>                    
                  </td>
                  <td class="text-right">
                    {% if incoming.telephone %}
                    <div>
                      <a href="tel:{{ incoming.telephone }}"><b>{{ incoming.telephone }}</b></a>
                    </div>
                    {% endif %}
                    {% if incoming.email %}
                    <div>
                      <a href="mailto:{{ incoming.email }}">{{ incoming.email }}</a>
                    </div>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    <div>{{ incoming.message }}</div>
                    {% if incoming.comment %}
                    <div>
                      <hr style="margin: 10px 0;">
                      <i class="fa fa-commenting-o text-primary"></i>
                      <span class="comment-text text-muted">{{ incoming.comment }}</span>
                    </div>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    <div style="white-space: nowrap;">
                      <small title="{{ text_date_added }}">
                        <i class="fa fa-calendar-plus-o text-danger"></i>
                        <b>{{ incoming.date_added }}</b>
                      </small>
                    </div>
                    {% if incoming.date_modified %}
                    <div>
                      <small title="{{ text_date_modified }}">
                        <i class="fa fa-calendar-check-o text-success"></i>
                        <b class="text-muted">{{ incoming.date_modified }}</b>
                      </small>
                    </div>
                    {% endif %}
                  </td>
                  <td class="text-left">
                    {% if incoming.status == 0 %}
                    <button type="button" class="status btn btn-danger">{{ text_status_new }}</button>
                    {% elseif incoming.status == 1 %}
                    <button type="button" class="btn btn-success">{{ text_status_done }}</button>
                    {% endif %}                    
                  </td>
                  <td class="text-right">
                    <button type="button" class="comment btn btn-primary" data-toggle="tooltip" title="{{ text_comment }}">
                      <i class="fa fa-commenting-o"></i>
                    </button>
                    <button type="button" class="btn btn-info" role="button" tabindex="0" data-container="body" data-toggle="popover" data-trigger="focus" data-placement="top" data-html="true" data-content="{{ incoming.user ? text_edited_by ~ '<b> ' ~ incoming.user ~ '</b><br>' : '' }}{{ text_ip }} <b>{{ incoming.ip }}</b><br><a href='{{ incoming.page_url }}' target='_blank'>{{ incoming.page_url }}</a>">
                      <i class="fa fa-info-circle"></i>
                    </button>
                    <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="delete btn btn-danger">
                      <i class="fa fa-trash-o"></i>
                    </button>
                  </td>
                </tr>
                {% endfor %}
                {% else %}
                <tr>
                  <td class="text-center" colspan="51">{{ text_no_results }}</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
        <div class="row">
          <div class="col-sm-6 text-left">{{ pagination }}</div>
          <div class="col-sm-6 text-right">{{ results }}</div>
        </div>
      </div>
    </div>
  </div>
</div>
<div id="edit-modal" class="modal fade" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
        <div class="modal-title h4">{{ text_modal_title }}</div>
      </div>
      <div class="modal-body">
        <form id="form-comment">
          <textarea name="comment" id="comment" class="form-control" placeholder="{{ text_comment }}" rows="5"></textarea>
          <input type="hidden" name="incoming_id" id="incoming_id" value="" />
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" id="save-comment" class="btn btn-primary">{{ button_save }}</button>
      </div>
    </div>
  </div>
</div>

<script>
$(document).ready(function() {
  $('body').popover({
    selector: '[data-toggle="popover"]',
    container: 'body',
    trigger: 'focus',
    placement: 'top',
    html: true
  });

  // status change
  $('body').on('click', 'button.status', function() {
    const $button = $(this);
    const $row = $button.closest('tr');
    const incoming_id = $row.find('input[name="selected[]"]').val();

    $.ajax({
      url: 'index.php?route=customer/incoming/status&user_token={{ user_token }}',
      type: 'post',
      data: { incoming_id: incoming_id },
      dataType: 'json',
      beforeSend: function() {
        $button.button('loading');
      },
      success: function(json) {
        $button.button('reset');

        if (json['success']) {
          $('#form-incoming').load(location.href + ' #form-incoming > *');
        }
      },
      error: function(xhr, status, error) {
        console.error(error);
      },
      complete: function() {
        $button.button('reset');
      }
    });
  });

  // comment change
  $('body').on('click', 'button.comment', function() {
    const $button = $(this);
    const $row = $button.closest('tr');
    const incoming_id = $row.find('input[name="selected[]"]').val();    

    $('#incoming_id').val(incoming_id);
    $('#comment').html($row.find('.comment-text').text().trim());
    $('#edit-modal').modal('show');
  });

  $('#save-comment').on('click', function(e) {
    const $button = $(this);
    const incoming_id = $('#incoming_id').val();
    const comment = $('#comment').val();

    $.ajax({
      url: 'index.php?route=customer/incoming/comment&user_token={{ user_token }}',
      type: 'post',
      data: { incoming_id: incoming_id, comment: comment },
      dataType: 'json',
      beforeSend: function() {
        $button.button('loading');
      },
      success: function(json) {
        $button.button('reset');

        if (json['success']) {
          $('#edit-modal').modal('hide');
          $('#form-incoming').load(location.href + ' #form-incoming > *');          
        }
      },
      error: function(xhr, status, error) {
        console.error(error);
      },
      complete: function() {
        $button.button('reset');
      }
    });
  });

  // handle delete
  $('body').on('click', 'button.delete', function() {
    const $button = $(this);
    const $row = $button.closest('tr');
    const incoming_id = $row.find('input[name="selected[]"]').val();    

    if (confirm('{{ text_confirm }}')) {
      $.ajax({
        url: 'index.php?route=customer/incoming/delete&user_token={{ user_token }}',
        type: 'post',
        data: { incoming_id: incoming_id },
        dataType: 'json',
        beforeSend: function() {
          $button.button('loading');
        },
        success: function(json) {
          $button.button('reset');

          if (json['success']) {
            $('#form-incoming').load(location.href + ' #form-incoming > *');
          }
        },
        error: function(xhr, status, error) {
          console.error(error);
        },
        complete: function() {
          $button.button('reset');
        }
      });
    }
  });
});
</script>
{{ footer }} 