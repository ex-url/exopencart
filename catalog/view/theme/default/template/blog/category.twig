{{ header }}
<main id="blog-category-page">
  <div class="container">
    <nav class="breadcrumb py-4" aria-label="breadcrumbs">
      <ul>
        {% for key, breadcrumb in breadcrumbs %}
        {% if key < (breadcrumbs|length - 1) %}
        <li>
          <a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
        </li>
        {% else %}
        <li>
          <span>{{ breadcrumb.text }}</span>
        </li>
        {% endif %}
        {% endfor %}
      </ul>
    </nav>
    <div class="columns is-multiline">
      {{ column_left }}
      {% if column_left and column_right %}
      {% set class = 'column is-6-fullhd is-6-widescreen is-6-desktop is-12-tablet is-12-mobile' %}
      {% elseif column_left or column_right %}
      {% set class = 'column is-9-fullhd is-9-widescreen is-9-desktop is-12-tablet is-12-mobile' %}
      {% else %}
      {% set class = 'column is-12' %}
      {% endif %}
      <div id="content" class="{{ class }}">
        {{ content_top }}
        <h1 class="title is-1">{{ heading_title }}</h1>
        {% if description %}
        <div class="content">{{ description }}</div>
        {% endif %}
        {% if categories %}
        <hr>
        <div class="pb-5">
          {% for category in categories %}
          <a href="{{ category.href }}" class="tag is-primary is-light" title="{{ category.title }}">
            {{ category.name }}
          </a>
          {% endfor %}
        </div>
        {% endif %}
        {% if articles %}
        {% if column_left and column_right %}
        {% set class = 'column is-6-fullhd is-6-widescreen is-6-desktop is-6-tablet is-12-mobile' %}
        {% elseif column_left or column_right %}
        {% set class = 'column is-6-fullhd is-6-widescreen is-6-desktop is-6-tablet is-12-mobile' %}
        {% else %}
        {% set class = 'column is-4-fullhd is-4-desktop is-6-tablet is-12-mobile' %}
        {% endif %}
        <div class="columns is-mobile is-multiline mt-5 blog-cards">
          {% for article in articles %}
          <div class="{{ class }}">
            <article class="blog-card card">
              <div class="card-image">
                <a href="{{ article['href'] }}" class="has-text-centered image">
                  <img src="{{ article['thumb'] }}" width="{{ image_width }}" height="{{ image_height }}" loading="lazy" alt="{{ article['name'] }}" title="{{ article['name'] }}" itemprop="image"/>
                </a>
              </div>
              <div class="card-content is-flex is-flex-direction-column is-justify-content-space-between">
                <div class="title is-5 mb-5" itemprop="headline"><a href="{{ article['href'] }}" itemprop="url">{{ article['name'] }}</a></div>
                <div class="announcement">
                  <p class="text">{{ article['description'] }} <a href="{{ article.href }}">{{ button_more }}</a></p>
                </div>
                {% if article.show_date or article.show_author or article.show_viewed %}
                <div class="is-flex is-justify-content-space-between is-align-items-center mt-5">
                  {% if article.show_author and article.author %}
                  <span class="icon-text">
                    <span class="icon has-text-primary">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="-0.5 -0.5 16 16" stroke-linecap="round" stroke-linejoin="round" stroke="currentColor" height="24" width="24">
                        <path d="M5.9375 5.6875a1.5625 1.5625 0 1 0 3.125 0 1.5625 1.5625 0 1 0 -3.125 0" stroke-width="1"></path>
                        <path d="M4.375 12.8125v-0.8125c0.198125 -3.8668750000000003 6.051875 -3.8668750000000003 6.25 0v0.8125" stroke-width="1"></path>
                        <path d="M1.875 5.875c0 -1.4000000000000001 0 -2.1 0.2725 -2.6350000000000002a2.5 2.5 0 0 1 1.0925 -1.0925C3.775 1.875 4.475 1.875 5.875 1.875h3.25c1.4000000000000001 0 2.1 0 2.6350000000000002 0.2725a2.5 2.5 0 0 1 1.0925 1.0925C13.125 3.775 13.125 4.475 13.125 5.875v3.25c0 1.4000000000000001 0 2.1 -0.2725 2.6350000000000002a2.5 2.5 0 0 1 -1.0925 1.0925C11.225000000000001 13.125 10.525 13.125 9.125 13.125H5.875c-1.4000000000000001 0 -2.1 0 -2.6350000000000002 -0.2725a2.5 2.5 0 0 1 -1.0925 -1.0925C1.875 11.225000000000001 1.875 10.525 1.875 9.125z" stroke-width="1"></path>
                      </svg>
                    </span>
                    <span class="has-text-weight-bold">{{ article.author }}</span>
                  </span>
                  {% endif %}
                  {% if article.show_date or article.show_viewed %}
                  <div class="is-flex is-align-items-center is-justify-content-space-between">
                    {% if article.show_date %}
                    <span class="icon-text mr-2">
                      <span class="icon has-text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="-0.5 -0.5 16 16" stroke-linecap="round" stroke-linejoin="round" stroke="currentColor" height="24" width="24">
                          <path d="M10.3125 3.125V1.875m-5.625 1.25V1.875M2.03125 5h10.9375M6.25 8.75h2.5m-1.25 -1.25v2.5m-5.625 -3.7225c0 -1.3218750000000001 0 -1.983125 0.2725 -2.488125a2.435 2.435 0 0 1 1.0925 -1.031875C3.775 2.5 4.475 2.5 5.875 2.5h3.25c1.4000000000000001 0 2.1 0 2.6350000000000002 0.2575 0.470625 0.22625 0.8525 0.5874999999999999 1.0925 1.03125 0.2725 0.5062500000000001 0.2725 1.1675 0.2725 2.489375v3.07c0 1.3218750000000001 0 1.983125 -0.2725 2.488125a2.435 2.435 0 0 1 -1.0925 1.031875C11.225000000000001 13.125 10.525 13.125 9.125 13.125H5.875c-1.4000000000000001 0 -2.1 0 -2.6350000000000002 -0.2575a2.435 2.435 0 0 1 -1.0925 -1.03125C1.875 11.33 1.875 10.66875 1.875 9.346875z" stroke-width="1"></path>
                        </svg>
                      </span>
                      <time class="has-text-grey" datetime="{{ article.date_published_iso }}">{{ article.date_published }}</time>
                    </span>
                    {% endif %}
                    {% if article.show_viewed %}
                    <span class="icon-text">
                      <span class="icon has-text-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="-0.5 -0.5 16 16" stroke-linecap="round" stroke-linejoin="round" stroke="currentColor" height="24" width="24">
                          <path d="M1.59375 8.37875c-0.17 -0.233125 -0.255 -0.35000000000000003 -0.31375 -0.5750000000000001a1.5375 1.5375 0 0 1 0 -0.6068749999999999c0.05875 -0.225625 0.14375000000000002 -0.3425 0.31375 -0.5750000000000001C2.524375 5.34375 4.564375 3.125 7.5 3.125c2.935625 0 4.975625 2.21875 5.90625 3.4962500000000003 0.17 0.233125 0.255 0.35000000000000003 0.31375 0.5750000000000001a1.5375 1.5375 0 0 1 0 0.6068749999999999c-0.05875 0.225625 -0.14375000000000002 0.3425 -0.31375 0.5750000000000001C12.475624999999999 9.65625 10.435625 11.875 7.5 11.875c-2.935625 0 -4.975625 -2.21875 -5.90625 -3.4962500000000003" stroke-width="1"></path>
                          <path d="M7.5 8.75a1.25 1.25 0 1 0 0 -2.5 1.25 1.25 0 0 0 0 2.5" stroke-width="1"></path>
                        </svg>
                      </span>
                      <span class="has-text-grey">{{ article.viewed }}</span>
                    </span>
                    {% endif %}
                  </div>
                  {% endif %}
                </div>  
                {% endif %}
              </div>
            </article>
          </div>
          {% endfor %}
        </div>
        <div class="columns is-align-items-center is-justify-content-space-between my-3">
          <div class="column is-narrow">{{ pagination }}</div>
          <div class="column is-narrow">{{ results }}</div>
        </div>
        {% else %}
        <p>{{ text_empty }}</p>
        <div class="buttons my-5">
          <a href="{{ continue }}" class="button is-primary is-light">{{ button_continue }}</a>
        </div>
        {% endif %}
      </div>
      {{ column_right }}
    </div>
  </div>
  {{ content_bottom }}
</main>
{{ footer }}
